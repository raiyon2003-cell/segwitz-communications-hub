generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DEPARTMENT_MANAGER
  STAFF
  VIEW_ONLY
}

enum TemplateStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ARCHIVED
}

enum ContactType {
  CLIENT
  PROSPECT
  EMPLOYEE
  CANDIDATE
  VENDOR
  PARTNER
}

enum TemplateType {
  RICH_TEXT
  HTML
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

enum ApprovalAction {
  SUBMITTED
  APPROVED
  REJECTED
}

model Division {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  departments Department[]

  @@map("divisions")
}

model Department {
  id         String   @id @default(cuid())
  name       String
  divisionId String   @map("division_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  division       Division        @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  users          User[]
  emailTemplates EmailTemplate[]
  sentEmails     SentEmail[]

  @@unique([divisionId, name])
  @@index([divisionId])
  @@map("departments")
}

model User {
  id           String   @id @default(cuid())
  authId       String   @unique @map("auth_id")
  email        String   @unique
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  role         Role     @default(STAFF)
  departmentId String?  @map("department_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  department        Department?        @relation(fields: [departmentId], references: [id])
  ownedTemplates    EmailTemplate[]    @relation("TemplateOwner")
  sentEmails        SentEmail[]
  templateApprovals TemplateApproval[]
  auditLogs         AuditLog[]

  @@index([departmentId])
  @@index([role])
  @@map("users")
}

model Contact {
  id          String      @id @default(cuid())
  name        String
  company     String?
  email       String
  contactType ContactType @map("contact_type")
  notes       String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  sentEmails              SentEmail[]
  communicationTimelines  CommunicationTimeline[]

  @@index([email])
  @@index([contactType])
  @@index([name])
  @@map("contacts")
}

model EmailCategory {
  id          String   @id @default(cuid())
  name        String
  department  String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  emailTemplates EmailTemplate[]

  @@unique([name, department])
  @@map("email_categories")
}

model EmailTemplate {
  id           String         @id @default(cuid())
  name         String
  departmentId String         @map("department_id")
  categoryId   String         @map("category_id")
  subject      String
  body         String         @db.Text
  templateType TemplateType   @default(RICH_TEXT) @map("template_type")
  htmlFileUrl  String?        @map("html_file_url")
  htmlContent  String?        @map("html_content") @db.Text
  status       TemplateStatus @default(DRAFT)
  ownerId      String         @map("owner_id")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  department             Department              @relation(fields: [departmentId], references: [id])
  category               EmailCategory           @relation(fields: [categoryId], references: [id])
  owner                  User                    @relation("TemplateOwner", fields: [ownerId], references: [id])
  variables              TemplateVariable[]
  sentEmails             SentEmail[]
  templateApprovals      TemplateApproval[]
  communicationTimelines CommunicationTimeline[]

  @@index([departmentId])
  @@index([categoryId])
  @@index([status])
  @@index([ownerId])
  @@map("email_templates")
}

model TemplateVariable {
  id           String   @id @default(cuid())
  templateId   String   @map("template_id")
  variableName String   @map("variable_name")
  label        String?
  isRequired   Boolean  @default(true) @map("is_required")
  createdAt    DateTime @default(now()) @map("created_at")

  template EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, variableName])
  @@index([templateId])
  @@map("template_variables")
}

model SentEmail {
  id             String      @id @default(cuid())
  recipient      String
  cc             String?
  bcc            String?
  subject        String
  body           String      @db.Text
  templateId     String?     @map("template_id")
  contactId      String?     @map("contact_id")
  departmentId   String?     @map("department_id")
  sentById       String      @map("sent_by_id")
  status         EmailStatus @default(PENDING)
  brevoMessageId String?     @map("brevo_message_id")
  errorMessage   String?     @map("error_message") @db.Text
  sentAt         DateTime    @default(now()) @map("sent_at")
  createdAt      DateTime    @default(now()) @map("created_at")

  template               EmailTemplate?          @relation(fields: [templateId], references: [id])
  contact                Contact?                @relation(fields: [contactId], references: [id])
  department             Department?             @relation(fields: [departmentId], references: [id])
  sentBy                 User                    @relation(fields: [sentById], references: [id])
  attachments            EmailAttachment[]
  emailLogs              EmailLog[]
  communicationTimelines CommunicationTimeline[]

  @@index([recipient])
  @@index([templateId])
  @@index([departmentId])
  @@index([sentById])
  @@index([status])
  @@index([sentAt])
  @@map("sent_emails")
}

model EmailAttachment {
  id          String   @id @default(cuid())
  sentEmailId String?  @map("sent_email_id")
  fileName    String   @map("file_name")
  fileUrl     String   @map("file_url")
  fileSize    Int      @map("file_size")
  mimeType    String   @map("mime_type")
  createdAt   DateTime @default(now()) @map("created_at")

  sentEmail SentEmail? @relation(fields: [sentEmailId], references: [id], onDelete: Cascade)

  @@index([sentEmailId])
  @@map("email_attachments")
}

model EmailLog {
  id          String   @id @default(cuid())
  sentEmailId String   @map("sent_email_id")
  event       String
  details     String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  sentEmail SentEmail @relation(fields: [sentEmailId], references: [id], onDelete: Cascade)

  @@index([sentEmailId])
  @@map("email_logs")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  isSecret  Boolean  @default(false) @map("is_secret")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model TemplateApproval {
  id         String         @id @default(cuid())
  templateId String         @map("template_id")
  approverId String         @map("approver_id")
  action     ApprovalAction
  comments   String?        @db.Text
  createdAt  DateTime       @default(now()) @map("created_at")

  template EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  approver User          @relation(fields: [approverId], references: [id])

  @@index([templateId])
  @@map("template_approvals")
}

model CommunicationTimeline {
  id          String   @id @default(cuid())
  contactId   String   @map("contact_id")
  sentEmailId String?  @map("sent_email_id")
  templateId  String?  @map("template_id")
  title       String
  description String?  @db.Text
  occurredAt  DateTime @map("occurred_at")
  createdAt   DateTime @default(now()) @map("created_at")

  contact   Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  sentEmail SentEmail?     @relation(fields: [sentEmailId], references: [id], onDelete: SetNull)
  template  EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([occurredAt])
  @@map("communication_timelines")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  details    String?  @db.Text
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}
