# Database (Supabase PostgreSQL) — use DIRECT connection (Settings > Database > URI)
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Encryption (32+ characters for API key encryption)
ENCRYPTION_KEY="your-32-character-minimum-encryption-key!!"

# Brevo (configured via Settings UI, optional env fallback)
BREVO_API_KEY=""

# External API access for future integrations
SCH_API_KEY="your-secure-api-key-for-external-systems"

# Seed script (optional)
SEED_ADMIN_EMAIL="admin@segwitz.com"
SEED_ADMIN_PASSWORD="Admin123!"

# App URL (for password reset redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
